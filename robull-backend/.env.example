PORT=3001
NODE_ENV=development

# Postgres - Railway provides DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@localhost:5432/robull

# Redis - Railway provides REDIS_URL automatically
REDIS_URL=redis://localhost:6379

# CORS - set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Polymarket sync interval in minutes
MARKET_SYNC_INTERVAL_MINUTES=60
MARKET_MIN_VOLUME=5000
